# ── Required ────────────────────────────────────────────────────────────────
WORKOS_SECRET_KEY=change-me-long-random
# Seeded admin account (optional but handy)
WORKOS_ADMIN_EMAIL=
WORKOS_ADMIN_PASSWORD=

# ── Chain (X Layer mainnet) ─────────────────────────────────────────────────
XLAYER_RPC_URL=https://rpc.xlayer.tech
CHAIN_ID=196
SIGNATURE_REGISTRY_ADDRESS=0x78fBD5B1b50B80045a03D272D12B357a374a01c3

# ── LLM chain (Gemini -> Groq fallback) ─────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8011
PUBLIC_BASE_URL=http://localhost:8011
DATABASE_PATH=./workos.db

# ── Scanner ─────────────────────────────────────────────────────────────────
SCANNER_ENABLED=1
SCANNER_TICK_SECONDS=300

# ── Newly-funded pipeline ───────────────────────────────────────────────────
FUNDING_ENABLED=1
FUNDING_TICK_SECONDS=21600
FUNDING_FRESH_DAYS=90

# ── Proof-of-work layer ─────────────────────────────────────────────────────
# GitHub OAuth app (callback: {PUBLIC_BASE_URL}/v1/proof/github/callback).
# Unset = users connect in public-repos mode by username, no token stored.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Read-side RPC / indexer for wallet footprint lookups
ETH_RPC_URL=https://cloudflare-eth.com
SNAPSHOT_HUB_URL=https://hub.snapshot.org/graphql

# ── Digest email (unset = subscriptions captured, sends skipped) ────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=WorkOS <no-reply@example.com>
